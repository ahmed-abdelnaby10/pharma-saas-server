// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PreferredLanguage {
  en
  ar
}

enum TenantStatus {
  active
  suspended
  inactive
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum BillingInterval {
  monthly
  yearly
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model Tenant {
  id                String            @id @default(cuid())
  nameEn            String
  nameAr            String
  preferredLanguage PreferredLanguage @default(en)
  status            TenantStatus      @default(active)
  isTrialActive     Boolean           @default(true)
  trialEndsAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  settings      TenantSettings?
  users         TenantUser[]
  subscriptions Subscription[]
  branches      Branch[]
  roles           Role[]
  suppliers       Supplier[]
  inventoryItems  InventoryItem[]
  inventoryBatches InventoryBatch[]

  @@index([status])
  @@index([trialEndsAt])
  @@index([preferredLanguage])
}

model TenantSettings {
  id                   String            @id @default(cuid())
  tenantId             String            @unique
  organizationName     String?
  taxId                String?
  phone                String?
  email                String?
  lowStockAlerts       Boolean           @default(true)
  expiryAlerts         Boolean           @default(true)
  purchaseOrderUpdates Boolean           @default(true)
  receiptHeader        String?
  receiptFooter        String?
  vatPercentage        Decimal           @default(0) @db.Decimal(5, 2)
  defaultLanguage      PreferredLanguage @default(en)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Plan {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  description     String?
  billingInterval BillingInterval
  price           Decimal         @db.Decimal(12, 2)
  currency        String          @default("EGP")
  trialDays       Int             @default(14)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@index([isActive])
  @@index([billingInterval, isActive])
}

model PlanFeature {
  id         String   @id @default(cuid())
  planId     String
  featureKey String
  enabled    Boolean  @default(true)
  limitValue Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model Subscription {
  id          String             @id @default(cuid())
  tenantId    String
  planId      String
  status      SubscriptionStatus @default(trialing)
  startsAt    DateTime
  endsAt      DateTime?
  trialEndsAt DateTime?
  canceledAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([planId])
  @@index([trialEndsAt])
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  nameEn    String
  nameAr    String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          TenantUser[]
  inventoryItems InventoryItem[]

  @@unique([tenantId, nameEn])
  @@unique([tenantId, nameAr])
  @@index([tenantId, isActive])
  @@index([tenantId, isDefault])
}

model TenantUser {
  id                String             @id @default(cuid())
  tenantId          String
  branchId          String?
  email             String
  passwordHash      String
  fullName          String
  isActive          Boolean            @default(true)
  preferredLanguage PreferredLanguage?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userRoles UserRole[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@index([tenantId, branchId])
}

model Permission {
  id        String   @id @default(cuid())
  code      String   @unique
  nameEn    String
  nameAr    String
  module    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([module])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  nameEn    String
  nameAr    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model CatalogItem {
  id            String   @id @default(cuid())
  nameEn        String
  nameAr        String
  genericNameEn String?
  genericNameAr String?
  barcode       String?  @unique
  sku           String?  @unique
  category      String?
  unitOfMeasure String
  dosageForm    String?
  strength      String?
  manufacturer  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryItems InventoryItem[]

  @@index([isActive])
  @@index([category])
  @@index([barcode])
  @@index([sku])
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  nameEn      String
  nameAr      String
  phone       String?
  email       String?
  address     String?
  taxId       String?
  contactName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches  InventoryBatch[]

  @@unique([tenantId, nameEn])
  @@unique([tenantId, nameAr])
  @@index([tenantId, isActive])
}

model InventoryItem {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String
  catalogItemId  String
  quantityOnHand Decimal  @default(0) @db.Decimal(12, 3)
  reorderLevel   Decimal? @db.Decimal(12, 3)
  sellingPrice   Decimal? @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem      @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  batches     InventoryBatch[]

  @@unique([branchId, catalogItemId])
  @@index([tenantId, branchId])
  @@index([tenantId, isActive])
  @@index([catalogItemId])
}

model InventoryBatch {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  inventoryItemId  String
  supplierId       String?
  batchNumber      String
  expiryDate       DateTime
  quantityReceived Decimal  @db.Decimal(12, 3)
  quantityOnHand   Decimal  @db.Decimal(12, 3)
  costPrice        Decimal? @db.Decimal(12, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplier      Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@unique([inventoryItemId, batchNumber])
  @@index([tenantId, branchId])
  @@index([inventoryItemId, isActive])
  @@index([expiryDate])
  @@index([supplierId])
}
