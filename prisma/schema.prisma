// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PreferredLanguage {
  en
  ar
}

enum TenantStatus {
  active
  suspended
  inactive
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum BillingInterval {
  monthly
  yearly
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
  RECONCILIATION_IN // Manual fix: add stock to correct an oversell discrepancy
  RECONCILIATION_OUT // Manual fix: remove stock to correct a discrepancy
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  INSURANCE
}

enum OcrDocumentType {
  INVOICE
  PRESCRIPTION
}

enum OcrDocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PlatformInvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketCategory {
  BILLING
  TECHNICAL
  GENERAL
  FEATURE_REQUEST
}

enum ActorType {
  PLATFORM_ADMIN
  TENANT_USER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PrescriptionStatus {
  PENDING
  DISPENSED
  CANCELLED
}

enum NotificationType {
  LOW_STOCK
  EXPIRY_ALERT
  OCR_COMPLETED
  OCR_FAILED
  SHIFT_OPENED
  SHIFT_CLOSED
  PURCHASE_ORDER_RECEIVED
  GENERAL
}

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String?
  actorId    String
  actorType  ActorType
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId, actorType])
  @@index([resource, action])
  @@index([createdAt])
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

model Tenant {
  id                String            @id @default(cuid())
  nameEn            String
  nameAr            String
  preferredLanguage PreferredLanguage @default(en)
  status            TenantStatus      @default(active)
  isTrialActive     Boolean           @default(true)
  trialEndsAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  settings         TenantSettings?
  users            TenantUser[]
  subscriptions    Subscription[]
  branches         Branch[]
  roles            Role[]
  suppliers        Supplier[]
  inventoryItems   InventoryItem[]
  inventoryBatches InventoryBatch[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  shifts           Shift[]
  sales            Sale[]
  payments         Payment[]
  ocrDocuments     OcrDocument[]
  platformInvoices PlatformInvoice[]
  supportTickets   SupportTicket[]
  auditLogs        AuditLog[]
  featureOverrides TenantFeatureOverride[]
  patients         Patient[]
  prescriptions    Prescription[]
  notifications    Notification[]
  devices          Device[]
  deviceSessions   DeviceSession[]

  @@index([status])
  @@index([trialEndsAt])
  @@index([preferredLanguage])
}

model TenantSettings {
  id                   String            @id @default(cuid())
  tenantId             String            @unique
  organizationName     String?
  taxId                String?
  phone                String?
  email                String?
  lowStockAlerts       Boolean           @default(true)
  expiryAlerts         Boolean           @default(true)
  purchaseOrderUpdates Boolean           @default(true)
  receiptHeader        String?
  receiptFooter        String?
  vatPercentage        Decimal           @default(0) @db.Decimal(5, 2)
  defaultLanguage      PreferredLanguage @default(en)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Plan {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  description     String?
  billingInterval BillingInterval
  price           Decimal         @db.Decimal(12, 2)
  currency        String          @default("EGP")
  trialDays       Int             @default(14)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  features      PlanFeature[]
  subscriptions Subscription[]

  @@index([isActive])
  @@index([billingInterval, isActive])
}

model PlanFeature {
  id         String   @id @default(cuid())
  planId     String
  featureKey String
  enabled    Boolean  @default(true)
  limitValue Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model Subscription {
  id          String             @id @default(cuid())
  tenantId    String
  planId      String
  status      SubscriptionStatus @default(trialing)
  startsAt    DateTime
  endsAt      DateTime?
  trialEndsAt DateTime?
  canceledAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan             Plan              @relation(fields: [planId], references: [id])
  platformInvoices PlatformInvoice[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([planId])
  @@index([trialEndsAt])
}

model TenantFeatureOverride {
  id         String   @id @default(cuid())
  tenantId   String
  featureKey String
  enabled    Boolean  @default(true)
  limitValue Int?
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId])
}

model Patient {
  id          String    @id @default(cuid())
  tenantId    String
  fullName    String
  dateOfBirth DateTime?
  phone       String?
  email       String?
  nationalId  String? // Government / insurance ID — unique per tenant when provided
  gender      Gender?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales         Sale[]
  prescriptions Prescription[]

  @@unique([tenantId, nationalId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, fullName])
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  nameEn    String
  nameAr    String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          TenantUser[]
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  shifts         Shift[]
  sales          Sale[]
  ocrDocuments   OcrDocument[]
  prescriptions  Prescription[]
  devices        Device[]

  @@unique([tenantId, nameEn])
  @@unique([tenantId, nameAr])
  @@index([tenantId, isActive])
  @@index([tenantId, isDefault])
}

model TenantUser {
  id                String             @id @default(cuid())
  tenantId          String
  branchId          String?
  email             String
  passwordHash      String
  fullName          String
  isActive          Boolean            @default(true)
  preferredLanguage PreferredLanguage?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  userRoles      UserRole[]
  shifts         Shift[]
  ocrDocuments   OcrDocument[]
  supportTickets SupportTicket[]
  notifications  Notification[]
  deviceSessions DeviceSession[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@index([tenantId, branchId])
}

model Permission {
  id        String   @id @default(cuid())
  code      String   @unique
  nameEn    String
  nameAr    String
  module    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([module])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  nameEn    String
  nameAr    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model CatalogItem {
  id            String   @id @default(cuid())
  nameEn        String
  nameAr        String
  genericNameEn String?
  genericNameAr String?
  barcode       String?  @unique
  sku           String?  @unique
  category      String?
  unitOfMeasure String
  dosageForm    String?
  strength      String?
  manufacturer  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventoryItems InventoryItem[]

  @@index([isActive])
  @@index([category])
  @@index([barcode])
  @@index([sku])
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  nameEn      String
  nameAr      String
  phone       String?
  email       String?
  address     String?
  taxId       String?
  contactName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches        InventoryBatch[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, nameEn])
  @@unique([tenantId, nameAr])
  @@index([tenantId, isActive])
}

model InventoryItem {
  id             String   @id @default(cuid())
  tenantId       String
  branchId       String
  catalogItemId  String
  quantityOnHand Decimal  @default(0) @db.Decimal(12, 3)
  reorderLevel   Decimal? @db.Decimal(12, 3)
  sellingPrice   Decimal? @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  catalogItem        CatalogItem         @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  batches            InventoryBatch[]
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  saleItems          SaleItem[]

  @@unique([branchId, catalogItemId])
  @@index([tenantId, branchId])
  @@index([tenantId, isActive])
  @@index([catalogItemId])
}

model InventoryBatch {
  id               String   @id @default(cuid())
  tenantId         String
  branchId         String
  inventoryItemId  String
  supplierId       String?
  batchNumber      String
  expiryDate       DateTime
  quantityReceived Decimal  @db.Decimal(12, 3)
  quantityOnHand   Decimal  @db.Decimal(12, 3)
  costPrice        Decimal? @db.Decimal(12, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem  InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]

  @@unique([inventoryItemId, batchNumber])
  @@index([tenantId, branchId])
  @@index([inventoryItemId, isActive])
  @@index([expiryDate])
  @@index([supplierId])
}

model StockMovement {
  id              String            @id @default(cuid())
  tenantId        String
  branchId        String
  inventoryItemId String
  batchId         String?
  movementType    StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  quantityBefore  Decimal           @db.Decimal(12, 3)
  quantityAfter   Decimal           @db.Decimal(12, 3)
  referenceType   String?
  referenceId     String?
  notes           String?
  externalId      String? // Client-generated sync ID for offline desktop reconciliation
  clientCreatedAt DateTime? // When the movement was recorded on the desktop (offline timestamp)
  createdAt       DateTime          @default(now())

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  batch         InventoryBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@unique([tenantId, externalId])
  @@index([tenantId, branchId])
  @@index([inventoryItemId])
  @@index([batchId])
  @@index([movementType])
  @@index([createdAt])
  @@index([referenceType, referenceId])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  branchId    String
  supplierId  String?
  orderNumber String
  status      PurchaseOrderStatus @default(DRAFT)
  notes       String?
  externalId  String? // Client-generated sync ID for offline desktop reconciliation
  orderedAt   DateTime?
  expectedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseOrderItem[]

  @@unique([tenantId, orderNumber])
  @@unique([tenantId, externalId])
  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id               String   @id @default(cuid())
  purchaseOrderId  String
  inventoryItemId  String
  quantityOrdered  Decimal  @db.Decimal(12, 3)
  quantityReceived Decimal  @default(0) @db.Decimal(12, 3)
  unitCost         Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([purchaseOrderId, inventoryItemId])
  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model Shift {
  id              String      @id @default(cuid())
  tenantId        String
  branchId        String
  userId          String
  status          ShiftStatus @default(OPEN)
  openingBalance  Decimal     @db.Decimal(12, 2)
  closingBalance  Decimal?    @db.Decimal(12, 2)
  notes           String?
  externalId      String? // Client-generated sync ID for offline desktop reconciliation
  openedAt        DateTime    @default(now())
  closedAt        DateTime?
  clientCreatedAt DateTime? // When the shift was opened on the desktop (offline timestamp)
  clientClosedAt  DateTime? // When the shift was closed on the desktop (offline timestamp)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch     @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user   TenantUser @relation(fields: [userId], references: [id], onDelete: Restrict)
  sales  Sale[]

  @@unique([tenantId, externalId])
  @@index([tenantId, branchId, status])
  @@index([tenantId, branchId])
  @@index([userId])
}

model Sale {
  id              String     @id @default(cuid())
  tenantId        String
  branchId        String
  shiftId         String
  saleNumber      String
  status          SaleStatus @default(COMPLETED)
  subtotal        Decimal    @db.Decimal(12, 2)
  vatPercentage   Decimal    @db.Decimal(5, 2)
  vatAmount       Decimal    @db.Decimal(12, 2)
  total           Decimal    @db.Decimal(12, 2)
  patientId       String?
  notes           String?
  externalId      String? // Client-generated sync ID for offline desktop reconciliation
  clientCreatedAt DateTime? // When the sale was recorded on the desktop (offline timestamp)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  shift        Shift         @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  patient      Patient?      @relation(fields: [patientId], references: [id], onDelete: SetNull)
  items        SaleItem[]
  payments     Payment[]
  prescription Prescription?

  @@unique([tenantId, saleNumber])
  @@unique([tenantId, externalId])
  @@index([tenantId, branchId])
  @@index([shiftId])
  @@index([tenantId, status])
  @@index([createdAt])
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  inventoryItemId String
  quantity        Decimal  @db.Decimal(12, 3)
  unitPrice       Decimal  @db.Decimal(12, 2)
  subtotal        Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([inventoryItemId])
}

model Payment {
  id            String        @id @default(cuid())
  saleId        String
  tenantId      String
  paymentMethod PaymentMethod
  amount        Decimal       @db.Decimal(12, 2)
  reference     String?
  createdAt     DateTime      @default(now())

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([tenantId])
}

model OcrDocument {
  id            String            @id @default(cuid())
  tenantId      String
  branchId      String
  documentType  OcrDocumentType
  status        OcrDocumentStatus @default(PENDING)
  fileName      String // original filename
  filePath      String // server-relative storage path
  mimeType      String
  fileSize      Int // bytes
  errorMessage  String?
  extractedData Json? // raw OCR result populated by processing slices
  reviewedAt    DateTime?
  reviewedById  String? // TenantUser who reviewed
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  reviewedBy TenantUser? @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId])
  @@index([tenantId, documentType, status])
  @@index([createdAt])
}

model PlatformInvoice {
  id             String                @id @default(cuid())
  tenantId       String
  subscriptionId String?
  invoiceNumber  String                @unique
  status         PlatformInvoiceStatus @default(DRAFT)
  amount         Decimal               @db.Decimal(12, 2)
  currency       String                @default("EGP")
  periodStart    DateTime
  periodEnd      DateTime
  dueDate        DateTime
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([status, dueDate])
  @@index([createdAt])
}

model SupportTicket {
  id             String                @id @default(cuid())
  tenantId       String
  submittedById  String
  subject        String
  description    String
  category       SupportTicketCategory @default(GENERAL)
  priority       SupportTicketPriority @default(MEDIUM)
  status         SupportTicketStatus   @default(OPEN)
  /**
   * PlatformAdmin ID (no enforced FK — platform admins live outside tenant graph)
   */
  assignedToId   String?
  resolutionNote String?
  resolvedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submittedBy TenantUser @relation(fields: [submittedById], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
  @@index([status, priority])
  @@index([createdAt])
}

model Prescription {
  id                 String             @id @default(cuid())
  tenantId           String
  branchId           String
  patientId          String?
  saleId             String?            @unique
  prescriptionNumber String?
  doctorName         String?
  doctorLicense      String?
  status             PrescriptionStatus @default(PENDING)
  issuedAt           DateTime?
  dispensedAt        DateTime?
  notes              String?
  // Placeholder for Phase 6 OCR integration — stored as plain string until OcrDocument model is wired
  ocrDocumentId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  patient Patient?           @relation(fields: [patientId], references: [id], onDelete: SetNull)
  sale    Sale?              @relation(fields: [saleId], references: [id], onDelete: SetNull)
  items   PrescriptionItem[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
}

model PrescriptionItem {
  id                 String   @id @default(cuid())
  prescriptionId     String
  drugName           String
  quantity           Decimal  @db.Decimal(12, 3)
  dosageInstructions String?
  createdAt          DateTime @default(now())

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  body      String
  metadata  Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
  @@index([tenantId, userId, createdAt])
}

/// Represents a physical desktop/POS device registered to a branch.
/// Enables per-device offline session tracking and device revocation.
model Device {
  id           String    @id @default(cuid())
  tenantId     String
  branchId     String
  fingerprint  String // Client-generated stable device identifier (e.g. machine UUID)
  label        String? // Human-readable label e.g. "Cashier Terminal 1"
  isActive     Boolean   @default(true)
  lastSyncAt   DateTime?
  registeredAt DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  sessions DeviceSession[]

  @@unique([tenantId, fingerprint])
  @@index([tenantId])
  @@index([tenantId, branchId])
  @@index([tenantId, isActive])
}

/// Long-lived offline session token issued to a registered device.
/// The plaintext token is returned once on issue; only the SHA-256 hash is stored.
model DeviceSession {
  id        String   @id @default(cuid())
  deviceId  String
  tenantId  String
  userId    String
  tokenHash String   @unique // SHA-256(plaintext token) — never store plaintext
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  device Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
}
