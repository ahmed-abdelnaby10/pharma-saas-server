{
  "info": {
    "name": "Tenant — Roles & Permissions (RBAC)",
    "_postman_id": "roles-v1",
    "description": "Role management, permission assignment to roles, and role assignment to users. All routes require a tenant JWT. Run the permissions seeder first: npx ts-node prisma/seed-permissions.ts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1/tenant", "type": "string" },
    { "key": "tenantToken", "value": "<replace_with_tenant_access_token>", "type": "string" },
    { "key": "roleId", "value": "<replace_with_role_id>", "type": "string" },
    { "key": "userId", "value": "<replace_with_user_id>", "type": "string" },
    { "key": "permissionId", "value": "<replace_with_permission_id>", "type": "string" }
  ],
  "item": [
    {
      "name": "Permissions",
      "item": [
        {
          "name": "List Permissions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/permissions", "host": ["{{baseUrl}}"], "path": ["permissions"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "description": "List all platform-defined permissions, grouped by module."
          }
        }
      ]
    },
    {
      "name": "Roles",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/roles", "host": ["{{baseUrl}}"], "path": ["roles"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "description": "List all roles for the tenant, each with their permissions."
          }
        },
        {
          "name": "Get Role",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/roles/{{roleId}}", "host": ["{{baseUrl}}"], "path": ["roles", "{{roleId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }]
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/roles", "host": ["{{baseUrl}}"], "path": ["roles"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"pharmacist\",\n  \"nameEn\": \"Pharmacist\",\n  \"nameAr\": \"صيدلاني\"\n}"
            }
          }
        },
        {
          "name": "Create Role — Manager",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/roles", "host": ["{{baseUrl}}"], "path": ["roles"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"branch_manager\",\n  \"nameEn\": \"Branch Manager\",\n  \"nameAr\": \"مدير فرع\"\n}"
            }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/roles/{{roleId}}", "host": ["{{baseUrl}}"], "path": ["roles", "{{roleId}}"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nameEn\": \"Senior Pharmacist\",\n  \"nameAr\": \"صيدلاني أول\"\n}"
            }
          }
        },
        {
          "name": "Deactivate Role",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/roles/{{roleId}}", "host": ["{{baseUrl}}"], "path": ["roles", "{{roleId}}"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }]
          }
        },
        {
          "name": "Assign Permissions to Role",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/roles/{{roleId}}/permissions", "host": ["{{baseUrl}}"], "path": ["roles", "{{roleId}}", "permissions"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissionIds\": [\"{{permissionId}}\"]\n}"
            },
            "description": "Assign one or more permissions to a role. Idempotent."
          }
        },
        {
          "name": "Remove Permissions from Role",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/roles/{{roleId}}/permissions", "host": ["{{baseUrl}}"], "path": ["roles", "{{roleId}}", "permissions"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permissionIds\": [\"{{permissionId}}\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "User Roles",
      "item": [
        {
          "name": "List User Roles",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}/roles", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "roles"] },
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }]
          }
        },
        {
          "name": "Assign Roles to User",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}/roles", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "roles"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleIds\": [\"{{roleId}}\"]\n}"
            },
            "description": "Assign roles to a user. Idempotent. All roleIds must belong to this tenant."
          }
        },
        {
          "name": "Remove Roles from User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}/roles", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}", "roles"] },
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleIds\": [\"{{roleId}}\"]\n}"
            }
          }
        }
      ]
    }
  ]
}
