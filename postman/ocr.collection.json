{
  "info": {
    "name": "OCR",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List OCR Documents",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
          { "key": "Accept-Language", "value": "en" }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents?branchId={{branchId}}",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents"],
          "query": [
            { "key": "branchId", "value": "{{branchId}}" },
            { "key": "documentType", "value": "INVOICE", "disabled": true },
            { "key": "status", "value": "PENDING", "disabled": true }
          ]
        },
        "description": "List OCR documents for a branch. Filter by documentType (INVOICE|PRESCRIPTION) and/or status (PENDING|PROCESSING|COMPLETED|FAILED)."
      }
    },
    {
      "name": "Get OCR Document",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents/{{documentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents", "{{documentId}}"]
        },
        "description": "Fetch a single OCR document by ID."
      }
    },
    {
      "name": "Upload OCR Document (Invoice PDF)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "/path/to/invoice.pdf" },
            { "key": "branchId", "value": "{{branchId}}", "type": "text" },
            { "key": "documentType", "value": "INVOICE", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents"]
        },
        "description": "Upload an invoice PDF for OCR processing. Returns a PENDING document record."
      }
    },
    {
      "name": "Upload OCR Document (Prescription Image)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "/path/to/prescription.jpg" },
            { "key": "branchId", "value": "{{branchId}}", "type": "text" },
            { "key": "documentType", "value": "PRESCRIPTION", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents"]
        },
        "description": "Upload a prescription image (JPEG/PNG/WEBP) for OCR processing."
      }
    },
    {
      "name": "Process Invoice Document (Trigger OCR)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents/{{documentId}}/process",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents", "{{documentId}}", "process"]
        },
        "description": "Enqueue an INVOICE document for async OCR processing. Document must be in PENDING status. Returns 202 immediately — poll GET /:documentId to track progress (PENDING → PROCESSING → COMPLETED/FAILED). extractedData is populated on COMPLETED."
      }
    },
    {
      "name": "Process Prescription Document (Trigger OCR)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents/{{prescriptionDocumentId}}/process",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents", "{{prescriptionDocumentId}}", "process"]
        },
        "description": "Enqueue a PRESCRIPTION document for async OCR processing. Document must be in PENDING status. Returns 202 immediately. extractedData on COMPLETED contains: patientName, doctorName, medications array (name, dosage, frequency, duration, quantity, instructions), notes, confidence."
      }
    },
    {
      "name": "Review OCR Document (Approve)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents/{{documentId}}/review",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents", "{{documentId}}", "review"]
        },
        "description": "Approve a COMPLETED OCR document as-is. Stamps reviewedAt and reviewedById. Document must not have been previously reviewed."
      }
    },
    {
      "name": "Review OCR Document (Approve with Corrections)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"correctedData\": {\n    \"invoiceNumber\": \"INV-2026-042\",\n    \"supplierName\": \"Corrected Supplier Name\",\n    \"totalAmount\": 130.00\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/tenant/ocr/documents/{{documentId}}/review",
          "host": ["{{baseUrl}}"],
          "path": ["tenant", "ocr", "documents", "{{documentId}}", "review"]
        },
        "description": "Approve a COMPLETED OCR document with manual corrections. correctedData replaces extractedData in full. reviewedAt and reviewedById are stamped."
      }
    }
  ]
}
