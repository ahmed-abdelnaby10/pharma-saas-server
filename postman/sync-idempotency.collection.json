{
  "info": {
    "name": "Sync / Idempotency",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Demonstrates the offline sync safety foundation: idempotent Sale and Shift operations via X-Idempotency-Key header and externalId field. StockMovement and PurchaseOrder have DB columns ready — wiring pending."
  },
  "item": [
    {
      "name": "POS",
      "item": [
        {
          "name": "Create Sale — first sync attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{$guid}}", "description": "Stable UUID for this logical operation — use the SAME value on every retry." },
              { "key": "X-Client-Id",       "value": "desktop-device-001", "description": "Optional device identifier." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"shiftId\": \"{{shiftId}}\",\n  \"externalId\": \"{{localSaleId}}\",\n  \"items\": [\n    {\n      \"inventoryItemId\": \"{{inventoryItemId}}\",\n      \"quantity\": 2,\n      \"unitPrice\": 150.00\n    }\n  ],\n  \"paymentMethod\": \"CASH\",\n  \"paymentAmount\": 300.00,\n  \"notes\": \"Offline sale synced from desktop\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/pos",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "pos"]
            },
            "description": "First submission. Response includes `meta.syncAck` with `fromCache: false`. Save the X-Idempotency-Key UUID — use it verbatim on retries. `externalId` is your local SQLite record ID."
          }
        },
        {
          "name": "Create Sale — retry (Redis cache hit)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{idempotencyKey}}", "description": "SAME key as the first attempt." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"shiftId\": \"{{shiftId}}\",\n  \"externalId\": \"{{localSaleId}}\",\n  \"items\": [\n    {\n      \"inventoryItemId\": \"{{inventoryItemId}}\",\n      \"quantity\": 2,\n      \"unitPrice\": 150.00\n    }\n  ],\n  \"paymentMethod\": \"CASH\",\n  \"paymentAmount\": 300.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/pos",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "pos"]
            },
            "description": "`meta.syncAck.fromCache` will be `true`. No new Sale created, no stock decremented."
          }
        },
        {
          "name": "Create Sale — retry (Redis expired, externalId dedup)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{$guid}}", "description": "NEW key (Redis cache miss). externalId carries the dedup." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"shiftId\": \"{{shiftId}}\",\n  \"externalId\": \"{{localSaleId}}\",\n  \"items\": [\n    {\n      \"inventoryItemId\": \"{{inventoryItemId}}\",\n      \"quantity\": 2,\n      \"unitPrice\": 150.00\n    }\n  ],\n  \"paymentMethod\": \"CASH\",\n  \"paymentAmount\": 300.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/pos",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "pos"]
            },
            "description": "Simulates a retry after the 24 h Redis TTL expired. New idempotency key causes a Redis cache miss, but `externalId` matches an existing Sale — service returns it without creating a duplicate."
          }
        },
        {
          "name": "Create Sale — standard (no sync headers)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"shiftId\": \"{{shiftId}}\",\n  \"items\": [\n    {\n      \"inventoryItemId\": \"{{inventoryItemId}}\",\n      \"quantity\": 1,\n      \"unitPrice\": 80.00\n    }\n  ],\n  \"paymentMethod\": \"CARD\",\n  \"paymentAmount\": 80.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/pos",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "pos"]
            },
            "description": "No X-Idempotency-Key, no externalId. Response has no `meta.syncAck`. Fully backward-compatible."
          }
        },
        {
          "name": "Get Sale (verify no duplicate)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/tenant/pos/{{saleId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "pos", "{{saleId}}"]
            },
            "description": "Confirm a single record with the expected total and externalId."
          }
        }
      ]
    },
    {
      "name": "Shifts",
      "item": [
        {
          "name": "Open Shift — first sync attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{$guid}}", "description": "Stable UUID — reuse on every retry of this open-shift operation." },
              { "key": "X-Client-Id",       "value": "desktop-device-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"openingBalance\": 500.00,\n  \"externalId\": \"{{localShiftId}}\",\n  \"notes\": \"Morning shift opened offline\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/shifts",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "shifts"]
            },
            "description": "Open a new shift with an externalId from the local SQLite store. Response includes `meta.syncAck.serverId` — use it to attach the server shift ID to the local record."
          }
        },
        {
          "name": "Open Shift — retry (Redis cache hit)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{shiftIdempotencyKey}}", "description": "SAME key as first open attempt." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"openingBalance\": 500.00,\n  \"externalId\": \"{{localShiftId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/shifts",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "shifts"]
            },
            "description": "Cached response returned, `syncAck.fromCache: true`. No new Shift created."
          }
        },
        {
          "name": "Open Shift — retry (Redis expired, externalId dedup)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{$guid}}", "description": "NEW key — simulates Redis TTL expiry." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branchId\": \"{{branchId}}\",\n  \"openingBalance\": 500.00,\n  \"externalId\": \"{{localShiftId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/shifts",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "shifts"]
            },
            "description": "Redis miss but `externalId` matches existing Shift — service returns it without creating a duplicate."
          }
        },
        {
          "name": "Close Shift — first sync attempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{$guid}}", "description": "Stable UUID for this close operation." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"closingBalance\": 1250.00,\n  \"notes\": \"End of day\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/shifts/{{shiftId}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "shifts", "{{shiftId}}", "close"]
            },
            "description": "Close a shift. Response includes `meta.syncAck`."
          }
        },
        {
          "name": "Close Shift — retry (idempotent, shift already closed)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization",     "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type",      "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "{{closeIdempotencyKey}}", "description": "SAME key as close attempt." }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"closingBalance\": 1250.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tenant/shifts/{{shiftId}}/close",
              "host": ["{{baseUrl}}"],
              "path": ["tenant", "shifts", "{{shiftId}}", "close"]
            },
            "description": "If within Redis TTL: served from cache (`fromCache: true`). If Redis expired: service detects CLOSED status and returns the closed shift without erroring. Either way, no duplicate close."
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "idempotencyKey",      "value": "", "description": "X-Idempotency-Key from first POS create attempt." },
    { "key": "localSaleId",         "value": "", "description": "Local SQLite sale externalId." },
    { "key": "shiftIdempotencyKey", "value": "", "description": "X-Idempotency-Key from first open-shift attempt." },
    { "key": "closeIdempotencyKey", "value": "", "description": "X-Idempotency-Key from first close-shift attempt." },
    { "key": "localShiftId",        "value": "", "description": "Local SQLite shift externalId." }
  ]
}
